OcYZsdLQ2CbXa4ftuuYR4x9vYZgdb4vsFYUdmABMYeukK9\/SUme3KMFQ77+Yfzh8eYF8+orDuDWU5LAAAAAElFTkSuQmCC","hasTimelineData":true,"timelineData":[{"name":"Event: pre_system","component":"Events","start":1776090483.747683,"duration":0.009330987930297852},{"name":"Event: DBQuery","component":"Events","start":1776090483.951439,"duration":3.814697265625e-5},{"name":"Event: DBQuery","component":"Events","start":1776090483.970424,"duration":2.3126602172851562e-5}]}],"vars":{"varData":{"View Data":{"page":"<div class=\"kint-rich\"><dl><dt class=\"kint-parent\"><span class=\"kint-folder-trigger\" title=\"Move to folder\"><\/span><span class=\"kint-search-trigger\" title=\"Show search box\"><\/span><input type=\"text\" class=\"kint-search\" value=\"\"><nav><\/nav><dfn>$value<\/dfn> <var>array<\/var> (9)<\/dt><dd><dl><dt><span class=\"kint-access-path-trigger\" title=\"Show access path\"><\/span><dfn>id<\/dfn> =&gt; <var>string<\/var> (1) \"1\"<div class=\"access-path\">$value['id']<\/div><\/dt><\/dl><dl><dt><span class=\"kint-access-path-trigger\" title=\"Show access path\"><\/span><dfn>slug<\/dfn> =&gt; <var>string<\/var> (27) \"profil-maziska-ppdi-pelindo\"<div class=\"access-path\">$value['slug']<\/div><\/dt><\/dl><dl><dt><span class=\"kint-access-path-trigger\" title=\"Show access path\"><\/span><dfn>title<\/dfn> =&gt; <var>string<\/var> (27) \"Profil Maziska PPDI Pelindo\"<div class=\"access-path\">$value['title']<\/div><\/dt><\/dl><dl><dt class=\"kint-parent\"><span class=\"kint-access-path-trigger\" title=\"Show access path\"><\/span><nav><\/nav><dfn>content<\/dfn> =&gt; <var>string<\/var> (2748) \"&lt;p&gt;&lt;strong&gt;Maziska PPDI Pelindo&lt;\/strong&gt; adalah lembaga zakat, infaq, dan sh...<div class=\"access-path\">$value['content']<\/div><\/dt><dd><pre>&lt;p&gt;&lt;strong&gt;Maziska PPDI Pelindo&lt;\/strong&gt; adalah lembaga zakat, infaq, dan shadaqah (ZIS) di bawah Dewan Pengurus Pusat Pembinaan Dakwah Islam (PPDI) PT Pelabuhan Indonesia (Persero). Fokus utamanya adalah menyalurkan dana sosial karyawan Pelindo untuk masyarakat sekitar, dengan program di bidang pendidikan, dakwah, ekonomi, kesehatan, dan tanggap bencana.&lt;\/p&gt;\r\n&lt;p&gt;&amp;nbsp;&lt;\/p&gt;\r\n&lt;p&gt;&lt;!--StartFragment --&gt;&lt;\/p&gt;\r\n&lt;p&gt;&lt;strong&gt;Ringkasan Profil Maziska PPDI Pelindo&lt;\/strong&gt;&lt;\/p&gt;\r\n&lt;ul&gt;\r\n&lt;li&gt;&lt;strong&gt;Nama lengkap:&lt;\/strong&gt; Maziska PPDI Pelindo (Persero)&lt;\/li&gt;\r\n&lt;li&gt;&lt;strong&gt;Bidang:&lt;\/strong&gt; Zakat, Infaq, Shadaqah (ZIS)&lt;\/li&gt;\r\n&lt;li&gt;&lt;strong&gt;Induk organisasi:&lt;\/strong&gt; Dewan Pengurus Pusat Pembinaan Dakwah Islam (PPDI) PT Pelabuhan Indonesia (Persero)&lt;\/li&gt;\r\n&lt;li&gt;&lt;strong&gt;Tujuan:&lt;\/strong&gt; Menyalurkan dana sosial karyawan Pelindo untuk kesejahteraan masyarakat, khususnya di sekitar wilayah kerja perusahaan.&lt;\/li&gt;\r\n&lt;li&gt;&lt;strong&gt;Program utama:&lt;\/strong&gt;&lt;\/li&gt;\r\n&lt;\/ul&gt;\r\n&lt;ul&gt;\r\n&lt;li&gt;&lt;strong&gt;Pendidikan &amp;amp; Tarbiyah Islamiyah&lt;\/strong&gt; &amp;ndash; bantuan pendidikan dan pembinaan keislaman.&lt;\/li&gt;\r\n&lt;li&gt;&lt;strong&gt;Pembangunan sarana ibadah &amp;amp; dakwah&lt;\/strong&gt; &amp;ndash; renovasi masjid, musholla, dan kegiatan dakwah.&lt;\/li&gt;\r\n&lt;li&gt;&lt;strong&gt;Pemberdayaan ekonomi &amp;amp; santunan sosial&lt;\/strong&gt; &amp;ndash; dukungan usaha kecil, santunan fakir miskin, anak yatim.&lt;\/li&gt;\r\n&lt;li&gt;&lt;strong&gt;Kesehatan&lt;\/strong&gt; &amp;ndash; kegiatan sosial kesehatan seperti sunatan massal.&lt;\/li&gt;\r\n&lt;li&gt;&lt;strong&gt;Tanggap bencana &amp;amp; musibah&lt;\/strong&gt; &amp;ndash; bantuan darurat bagi korban bencana.&lt;\/li&gt;\r\n&lt;\/ul&gt;\r\n&lt;p&gt;&amp;nbsp;&lt;\/p&gt;\r\n&lt;p&gt;&lt;strong&gt;Kegiatan&lt;\/strong&gt;&lt;\/p&gt;\r\n&lt;ul&gt;\r\n&lt;li&gt;&lt;strong&gt;Sunatan Massal 500 Anak di Pelabuhan Tanjung Priok (2022);&lt;\/strong&gt;&lt;\/li&gt;\r\n&lt;li&gt;&lt;strong&gt;Tebar Quran&lt;\/strong&gt;&lt;\/li&gt;\r\n&lt;li&gt;&lt;strong&gt;Sunatan Massal 384 Anak di Pelabuhan Makassar, Parepare, dan Palu (2023)&lt;\/strong&gt;&lt;\/li&gt;\r\n&lt;li&gt;&lt;strong&gt;Sunatan Massal di Pelabuhan Cirebon (2024):&lt;\/strong&gt;&lt;\/li&gt;\r\n&lt;\/ul&gt;\r\n&lt;p&gt;&lt;strong&gt;Peran &amp;amp; Dampak&lt;\/strong&gt;&lt;\/p&gt;\r\n&lt;ul&gt;\r\n&lt;li&gt;&lt;strong&gt;Meningkatkan kesejahteraan masyarakat sekitar pelabuhan&lt;\/strong&gt; melalui program sosial berkelanjutan.&lt;\/li&gt;\r\n&lt;li&gt;&lt;strong&gt;Mendukung visi Pelindo&lt;\/strong&gt; sebagai perusahaan yang tidak hanya berorientasi bisnis, tetapi juga peduli terhadap lingkungan sosial.&lt;\/li&gt;\r\n&lt;li&gt;&lt;strong&gt;Membangun citra positif perusahaan&lt;\/strong&gt; dengan kegiatan berbasis dakwah dan kepedulian sosial.&lt;\/li&gt;\r\n&lt;\/ul&gt;\r\n&lt;p&gt;&amp;nbsp;&lt;\/p&gt;\r\n&lt;p&gt;&lt;strong&gt;Maziska PPDI Pelindo&lt;\/strong&gt; adalah wadah zakat, infaq, dan shadaqah karyawan Pelindo yang berperan penting dalam &lt;strong&gt;mendistribusikan bantuan sosial secara terstruktur&lt;\/strong&gt;. Dengan lima sektor utama, lembaga ini menjadi jembatan antara perusahaan dan masyarakat, memastikan bahwa keberadaan Pelindo memberi manfaat nyata bagi lingkungan sekitar.&lt;\/p&gt;\r\n&lt;p&gt;&lt;!--EndFragment --&gt;&lt;\/p&gt;\n<\/pre><\/dd><\/dl><dl><dt class=\"kint-parent\"><span class=\"kint-access-path-trigger\" title=\"Show access path\"><\/span><nav><\/nav><dfn>image<\/dfn> =&gt; <var>string<\/var> (85) \"http:\/\/localhost\/compro_ppdi\/public\/uploads\/pages\/1774682339_45f5ab75ca55511...<div class=\"access-path\">$value['image']<\/div><\/dt><dd><pre>http:\/\/localhost\/compro_ppdi\/public\/uploads\/pages\/1774682339_45f5ab75ca555115ff43.jpg\n<\/pre><\/dd><\/dl><dl><dt><span class=\"kint-access-path-trigger\" title=\"Show access path\"><\/span><dfn>gallery<\/dfn> =&gt; <var>null<\/var><div class=\"access-path\">$value['gallery']<\/div><\/dt><\/dl